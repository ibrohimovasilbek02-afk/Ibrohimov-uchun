generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            Role      @default(USER)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Gamification
  xp              Int       @default(0)
  coins           Int       @default(0)
  level           Int       @default(1)
  streak          Int       @default(0)
  lastActiveDate  DateTime?
  bandPrediction  Float?

  // Premium
  isPremium       Boolean   @default(false)
  premiumUntil    DateTime?

  // AI Memory
  goal            String?
  lastBand        Float?
  motivationStyle String?
  favoriteJokes   String[]
  weakTopics      String[]
  strongTopics    String[]

  // Relations
  accounts        Account[]
  sessions        Session[]
  speakingSessions SpeakingSession[]
  writingSessions WritingSession[]
  readingSessions ReadingSession[]
  listeningSessions ListeningSession[]
  vocabularyProgress VocabularyProgress[]
  grammarProgress GrammarProgress[]
  achievements    UserAchievement[]
  dailyProgress   DailyProgress[]
  badges          UserBadge[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== SPEAKING ====================
model SpeakingSession {
  id              String   @id @default(cuid())
  userId          String
  part            Int      // 1, 2, or 3
  topic           String
  questions       Json     // Array of questions
  answers         Json     // Array of user answers (transcribed)
  feedback        Json     // AI feedback
  grammarScore    Float?
  pronunciationScore Float?
  fluencyScore    Float?
  vocabularyScore Float?
  bandScore       Float?
  duration        Int?     // seconds
  audioUrl        String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("speaking_sessions")
}

// ==================== WRITING ====================
model WritingSession {
  id              String   @id @default(cuid())
  userId          String
  taskType        WritingTask // TASK1 or TASK2
  topic           String
  essay           String   @db.Text
  feedback        Json     // AI feedback
  taskResponse    Float?
  coherence       Float?
  vocabulary      Float?
  grammar         Float?
  bandScore       Float?
  improvedEssay   String?  @db.Text
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("writing_sessions")
}

// ==================== READING ====================
model ReadingSession {
  id              String   @id @default(cuid())
  userId          String
  passage         String   @db.Text
  questions       Json     // Array of questions
  userAnswers     Json     // User's answers
  correctAnswers  Json     // Correct answers
  explanations    Json     // Why each answer is correct/wrong
  score           Int?
  totalQuestions   Int?
  timeSpent       Int?     // seconds
  bandScore       Float?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reading_sessions")
}

// ==================== LISTENING ====================
model ListeningSession {
  id              String   @id @default(cuid())
  userId          String
  audioUrl        String
  transcript      String   @db.Text
  questions       Json
  userAnswers     Json
  correctAnswers  Json
  explanations    Json
  score           Int?
  totalQuestions   Int?
  bandScore       Float?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("listening_sessions")
}

// ==================== VOCABULARY ====================
model Word {
  id              String   @id @default(cuid())
  word            String   @unique
  meaning         String
  meaningUz       String   // Uzbek meaning
  pronunciation   String?
  partOfSpeech    String?
  examples        String[]
  synonyms        String[]
  antonyms        String[]
  level           WordLevel
  topic           String?
  audioUrl        String?
  createdAt       DateTime @default(now())

  progress        VocabularyProgress[]

  @@map("words")
}

model VocabularyProgress {
  id              String   @id @default(cuid())
  userId          String
  wordId          String
  status          LearnStatus @default(NEW)
  correctCount    Int      @default(0)
  incorrectCount  Int      @default(0)
  lastReviewed    DateTime?
  nextReview      DateTime?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@map("vocabulary_progress")
}

// ==================== GRAMMAR ====================
model GrammarTopic {
  id              String   @id @default(cuid())
  title           String
  titleUz         String
  description     String   @db.Text
  descriptionUz   String   @db.Text
  level           GrammarLevel
  lesson          String   @db.Text
  lessonUz        String   @db.Text
  examples        Json
  quizQuestions   Json
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  progress        GrammarProgress[]

  @@map("grammar_topics")
}

model GrammarProgress {
  id              String   @id @default(cuid())
  userId          String
  topicId         String
  status          LearnStatus @default(NEW)
  quizScore       Float?
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic GrammarTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@map("grammar_progress")
}

// ==================== GAMIFICATION ====================
model Achievement {
  id              String   @id @default(cuid())
  name            String
  description     String
  icon            String
  category        AchievementCategory
  requirement     Json     // { type: "streak", value: 7 }
  xpReward        Int      @default(0)
  coinReward      Int      @default(0)
  createdAt       DateTime @default(now())

  users           UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id              String   @id @default(cuid())
  userId          String
  achievementId   String
  unlockedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Badge {
  id              String   @id @default(cuid())
  name            String
  description     String
  icon            String
  rarity          BadgeRarity
  createdAt       DateTime @default(now())

  users           UserBadge[]

  @@map("badges")
}

model UserBadge {
  id              String   @id @default(cuid())
  userId          String
  badgeId         String
  earnedAt        DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model DailyProgress {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  xpEarned        Int      @default(0)
  speakingMinutes Int      @default(0)
  writingWords    Int      @default(0)
  readingPassages Int      @default(0)
  listeningMinutes Int     @default(0)
  wordsLearned    Int      @default(0)
  grammarLessons  Int      @default(0)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_progress")
}

// ==================== ENUMS ====================
enum Role {
  USER
  ADMIN
}

enum WritingTask {
  TASK1
  TASK2
}

enum WordLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ACADEMIC
}

enum GrammarLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LearnStatus {
  NEW
  LEARNING
  REVIEWING
  MASTERED
}

enum AchievementCategory {
  SPEAKING
  WRITING
  READING
  LISTENING
  VOCABULARY
  GRAMMAR
  STREAK
  GENERAL
}

enum BadgeRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}
